# Credentials admin — à définir dans les variables d'environnement Vercel
VITE_ADMIN_EMAIL=votre@email.com
VITE_ADMIN_PASSWORD=votre_mot_de_passe

# Token secret partagé entre le frontend et l'API pour valider les actions admin
# Générer avec : openssl rand -hex 32
VITE_ADMIN_TOKEN=votre_token_secret
ADMIN_TOKEN=votre_token_secret   # même valeur, utilisé côté API (api/missions.ts)
